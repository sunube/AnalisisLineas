<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="data" numcolumns="8">
            <column name="id" display="none" order="10">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="tipo" order="20" numcolumns="4">
                <widget type="select" fieldname="tipo" required="true">
                    <values title="Mano de obra">mano_de_obra</values>
                    <values title="Material">material</values>
                </widget>
            </column>
            <column name="palabra-clave" order="30" numcolumns="8">
                <widget type="text" fieldname="palabra_clave" required="true"/>
            </column>
            <column name="activo" order="40" numcolumns="4">
                <widget type="checkbox" fieldname="activo"/>
            </column>
        </group>
    </columns>
</view>
