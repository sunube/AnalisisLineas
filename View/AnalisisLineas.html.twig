{% extends "Master/MenuBghTemplate.html.twig" %}

{% block body %}
<div class="container-fluid" style="padding-top: 15px;">

    {# ===== TITULO ===== #}
    <div class="row mb-3">
        <div class="col">
            <h1 class="h3">
                <i class="fas fa-chart-pie"></i> Análisis de Líneas de Facturas
            </h1>
            <p class="text-muted">Clasificación automática de líneas en Mano de Obra y Material</p>
        </div>
        <div class="col-auto">
            <a href="{{ asset('ConfigClasificacion') }}" class="btn btn-outline-secondary">
                <i class="fas fa-cogs"></i> Configurar palabras clave
            </a>
        </div>
    </div>

    {# ===== FILTROS ===== #}
    <form method="get" action="{{ asset('AnalisisLineas') }}" class="mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-filter"></i> Filtros
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2">
                        <label class="form-label"><strong>Desde</strong></label>
                        <input type="date" name="fechadesde" class="form-control" value="{{ fsc.fechaDesde }}">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label"><strong>Hasta</strong></label>
                        <input type="date" name="fechahasta" class="form-control" value="{{ fsc.fechaHasta }}">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label"><strong>Cliente</strong></label>
                        <select name="codcliente" class="form-control">
                            <option value="">-- Todos --</option>
                            {% for cliente in fsc.clientes %}
                            <option value="{{ cliente.codcliente }}" {{ fsc.codcliente == cliente.codcliente ? 'selected' : '' }}>
                                {{ cliente.nombrecliente }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label"><strong>Serie</strong></label>
                        <select name="codserie" class="form-control">
                            <option value="">-- Todas --</option>
                            {% for serie in fsc.series %}
                            <option value="{{ serie.codserie }}" {{ fsc.codserie == serie.codserie ? 'selected' : '' }}>
                                {{ serie.codserie }} - {{ serie.descripcion }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label"><strong>Clasificación</strong></label>
                        <select name="clasificacion" class="form-control">
                            <option value="">-- Todas --</option>
                            <option value="mano_de_obra" {{ fsc.clasificacion == 'mano_de_obra' ? 'selected' : '' }}>Mano de obra</option>
                            <option value="material" {{ fsc.clasificacion == 'material' ? 'selected' : '' }}>Material</option>
                            <option value="sin_clasificar" {{ fsc.clasificacion == 'sin_clasificar' ? 'selected' : '' }}>Sin clasificar</option>
                        </select>
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-md-6">
                        <input type="text" name="busqueda" class="form-control" placeholder="Buscar en descripción..." value="{{ fsc.busqueda }}">
                    </div>
                </div>
            </div>
        </div>
    </form>

    {# ===== RESUMEN CARDS ===== #}
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-left-primary" style="border-left: 4px solid #0d6efd;">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total Facturado</h6>
                    <h3 class="text-primary">{{ fsc.resumen.total_general|number_format(2, ',', '.') }} €</h3>
                    <small class="text-muted">{{ fsc.resumen.count_total }} líneas</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm" style="border-left: 4px solid #198754;">
                <div class="card-body text-center">
                    <h6 class="text-muted"><i class="fas fa-hard-hat"></i> Mano de Obra</h6>
                    <h3 class="text-success">{{ fsc.resumen.total_mano_obra|number_format(2, ',', '.') }} €</h3>
                    <small class="text-muted">{{ fsc.resumen.count_mano_obra }} líneas ({{ fsc.resumen.pct_mano_obra }}%)</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm" style="border-left: 4px solid #fd7e14;">
                <div class="card-body text-center">
                    <h6 class="text-muted"><i class="fas fa-box"></i> Material</h6>
                    <h3 style="color: #fd7e14;">{{ fsc.resumen.total_material|number_format(2, ',', '.') }} €</h3>
                    <small class="text-muted">{{ fsc.resumen.count_material }} líneas ({{ fsc.resumen.pct_material }}%)</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm" style="border-left: 4px solid #6c757d;">
                <div class="card-body text-center">
                    <h6 class="text-muted"><i class="fas fa-question-circle"></i> Sin Clasificar</h6>
                    <h3 class="text-secondary">{{ fsc.resumen.total_sin_clasificar|number_format(2, ',', '.') }} €</h3>
                    <small class="text-muted">{{ fsc.resumen.count_sin_clasificar }} líneas ({{ fsc.resumen.pct_sin_clasificar }}%)</small>
                </div>
            </div>
        </div>
    </div>

    {# ===== GRAFICOS ===== #}
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header"><i class="fas fa-chart-pie"></i> Distribución</div>
                <div class="card-body">
                    <canvas id="graficoPastel" height="250"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header"><i class="fas fa-chart-bar"></i> Evolución Mensual</div>
                <div class="card-body">
                    <canvas id="graficoMensual" height="250"></canvas>
                </div>
            </div>
        </div>
    </div>

    {# ===== TABLA DE RESULTADOS ===== #}
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-list"></i> Detalle de Líneas</span>
            <form method="get" action="{{ asset('AnalisisLineas') }}" class="d-inline">
                <input type="hidden" name="fechadesde" value="{{ fsc.fechaDesde }}">
                <input type="hidden" name="fechahasta" value="{{ fsc.fechaHasta }}">
                <input type="hidden" name="codcliente" value="{{ fsc.codcliente }}">
                <input type="hidden" name="codserie" value="{{ fsc.codserie }}">
                <input type="hidden" name="clasificacion" value="{{ fsc.clasificacion }}">
                <input type="hidden" name="busqueda" value="{{ fsc.busqueda }}">
                <input type="hidden" name="export" value="csv">
                <button type="submit" class="btn btn-sm btn-outline-success">
                    <i class="fas fa-file-csv"></i> Exportar CSV
                </button>
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Factura</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Descripción</th>
                            <th class="text-end">Cantidad</th>
                            <th class="text-end">Precio Ud.</th>
                            <th class="text-end">Dto %</th>
                            <th class="text-end">Total</th>
                            <th class="text-center">Clasificación</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for linea in fsc.resultados %}
                        <tr>
                            <td>
                                <a href="{{ asset('EditFacturaCliente') }}?code={{ linea.idfactura }}">
                                    {{ linea.codigo }}
                                </a>
                            </td>
                            <td>{{ linea.fecha }}</td>
                            <td>{{ linea.nombrecliente }}</td>
                            <td>{{ linea.descripcion|slice(0, 80) }}{% if linea.descripcion|length > 80 %}...{% endif %}</td>
                            <td class="text-end">{{ linea.cantidad|number_format(2, ',', '.') }}</td>
                            <td class="text-end">{{ linea.pvpunitario|number_format(2, ',', '.') }} €</td>
                            <td class="text-end">{{ linea.dtopor|number_format(1, ',', '.') }}%</td>
                            <td class="text-end"><strong>{{ linea.pvptotal|number_format(2, ',', '.') }} €</strong></td>
                            <td class="text-center">
                                {% if linea.clasificacion == 'mano_de_obra' %}
                                    <span class="badge bg-success"><i class="fas fa-hard-hat"></i> Mano de obra</span>
                                {% elseif linea.clasificacion == 'material' %}
                                    <span class="badge bg-warning text-dark"><i class="fas fa-box"></i> Material</span>
                                {% else %}
                                    <span class="badge bg-secondary"><i class="fas fa-question"></i> Sin clasificar</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                No se encontraron líneas con los filtros seleccionados
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Paginación #}
        {% if fsc.totalPaginas > 1 %}
        <div class="card-footer">
            <nav>
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    {% if fsc.pagina > 0 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ asset('AnalisisLineas') }}?fechadesde={{ fsc.fechaDesde }}&fechahasta={{ fsc.fechaHasta }}&codcliente={{ fsc.codcliente }}&codserie={{ fsc.codserie }}&clasificacion={{ fsc.clasificacion }}&busqueda={{ fsc.busqueda }}&pagina={{ fsc.pagina - 1 }}">
                            &laquo; Anterior
                        </a>
                    </li>
                    {% endif %}

                    <li class="page-item disabled">
                        <span class="page-link">Página {{ fsc.pagina + 1 }} de {{ fsc.totalPaginas }}</span>
                    </li>

                    {% if fsc.pagina < fsc.totalPaginas - 1 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ asset('AnalisisLineas') }}?fechadesde={{ fsc.fechaDesde }}&fechahasta={{ fsc.fechaHasta }}&codcliente={{ fsc.codcliente }}&codserie={{ fsc.codserie }}&clasificacion={{ fsc.clasificacion }}&busqueda={{ fsc.busqueda }}&pagina={{ fsc.pagina + 1 }}">
                            Siguiente &raquo;
                        </a>
                    </li>
                    {% endif %}
                </ul>
            </nav>
        </div>
        {% endif %}
    </div>

</div>
{% endblock %}

{% block css %}
<style>
    .border-left-primary { border-left: 4px solid #0d6efd !important; }
    .card { margin-bottom: 0; }
    .table th { white-space: nowrap; font-size: 0.85rem; }
    .table td { font-size: 0.85rem; vertical-align: middle; }
    .badge { font-size: 0.75rem; }
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Datos del servidor
    var datosGrafico = {{ fsc.datosGrafico|json_encode|raw }};
    var datosMensual = {{ fsc.datosGraficoMensual|json_encode|raw }};

    // Gráfico de pastel
    var ctxPastel = document.getElementById('graficoPastel').getContext('2d');
    new Chart(ctxPastel, {
        type: 'doughnut',
        data: {
            labels: ['Mano de obra', 'Material', 'Sin clasificar'],
            datasets: [{
                data: [datosGrafico.mano_de_obra, datosGrafico.material, datosGrafico.sin_clasificar],
                backgroundColor: ['#198754', '#fd7e14', '#6c757d'],
                borderWidth: 2,
                borderColor: '#fff'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom' },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            var total = ctx.dataset.data.reduce(function(a, b) { return a + b; }, 0);
                            var pct = total > 0 ? ((ctx.raw / total) * 100).toFixed(1) : 0;
                            return ctx.label + ': ' + ctx.raw.toLocaleString('es-ES', {minimumFractionDigits: 2}) + ' € (' + pct + '%)';
                        }
                    }
                }
            }
        }
    });

    // Gráfico mensual
    var meses = Object.keys(datosMensual);
    var moData = meses.map(function(m) { return datosMensual[m].mano_de_obra || 0; });
    var matData = meses.map(function(m) { return datosMensual[m].material || 0; });
    var scData = meses.map(function(m) { return datosMensual[m].sin_clasificar || 0; });

    var ctxMensual = document.getElementById('graficoMensual').getContext('2d');
    new Chart(ctxMensual, {
        type: 'bar',
        data: {
            labels: meses,
            datasets: [
                {
                    label: 'Mano de obra',
                    data: moData,
                    backgroundColor: '#198754'
                },
                {
                    label: 'Material',
                    data: matData,
                    backgroundColor: '#fd7e14'
                },
                {
                    label: 'Sin clasificar',
                    data: scData,
                    backgroundColor: '#6c757d'
                }
            ]
        },
        options: {
            responsive: true,
            scales: {
                x: { stacked: true },
                y: {
                    stacked: true,
                    ticks: {
                        callback: function(val) { return val.toLocaleString('es-ES') + ' €'; }
                    }
                }
            },
            plugins: {
                legend: { position: 'bottom' },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            return ctx.dataset.label + ': ' + ctx.raw.toLocaleString('es-ES', {minimumFractionDigits: 2}) + ' €';
                        }
                    }
                }
            }
        }
    });
});
</script>
{% endblock %}
